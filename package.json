{
  "name": "personal-blog",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run prepare:media",
    "dev": "vite",
    "build": "npm run validate:content && npm run prepare:media && npm run render:social-card && vite build && npm run check:bundle",
    "preview": "vite preview",
    "new-post": "node scripts/new-post.js",
    "publish": "node scripts/publish-post.js",
    "validate:content": "node scripts/validate-content.js",
    "check:bundle": "node scripts/check-bundle-size.js",
    "capture:poster": "node scripts/capture-poster.js",
    "prepare:media": "node scripts/prepare-media.js",
    "render:social-card": "node scripts/render-social-card.js",
    "review:month": "node scripts/create-monthly-review.js",
    "test": "node --test scripts/*.test.js",
    "test:e2e": "playwright test",
    "test:publish": "node --test scripts/post-tools.test.js"
  },
  "dependencies": {
    "hast-util-sanitize": "^5.0.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "motion": "^12.42.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^4.4.1",
    "sharp": "^0.35.3",
    "vite": "^6.4.1"
  }
}
